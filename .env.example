# Agora Conversational AI Agent Configuration
# Get your credentials from: https://console.agora.io/

AGORA_APP_ID=your_app_id_here
AGORA_RESTFUL_KEY=your_restful_key_here
AGORA_RESTFUL_SECRET=your_restful_secret_here
AGORA_CHANNEL_TOKEN=

# Minimax TTS (direct API — no Agora needed)
# Get your credentials from: https://platform.minimax.io/
MINIMAX_TTS_KEY=your_api_key_here
MINIMAX_TTS_GROUP_ID=your_group_id_here
